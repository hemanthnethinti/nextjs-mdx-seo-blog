# Environment Variables
# Copy this file to .env and update with your actual values
# For Vercel, set BASE_URL and NODE_ENV in the dashboard.
# PORT is managed by Vercel automatically and should not be set there.

# Base URL for the application (used in SEO and sitemap generation)
BASE_URL=http://localhost:3000

# Node environment
NODE_ENV=production

# Port for the application
PORT=3000
